# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
# Optional: separate OpenRouter model for layout/screenshot analysis.
# If empty, the main generation model is used.
# OPENROUTER_LAYOUT_DETECTION_MODEL=google/gemini-2.5-flash
# Ограничение max_tokens вывода (дешевле при малом балансе OpenRouter).
# OPENROUTER_MAX_IMAGE_TOKENS=32000
# OPENROUTER_MAX_COMPLETION_TOKENS=8192

# Background removal service (choose one, or leave empty to disable)
# Option A: Replicate — BRIA-RMBG-2.0 (best quality, ~$0.003/image)
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-token-here

# Option B: remove.bg (50 free/month, then ~$0.10/image)
# Get key: https://www.remove.bg/api
# REMOVE_BG_API_KEY=your-key-here

# ─── Telegram bot interface ─────────────────────────────────────────────────
# Telegram bot token from @BotFather (required to run `npm run bot`)
TELEGRAM_BOT_TOKEN=
# Optional: comma-separated list of Telegram user IDs that may use the bot.
# Leave empty to allow everyone.
TELEGRAM_ALLOWED_USER_IDS=
# Optional override for where the bot persists styles / rules / history.
# When MONGO_URI is set, only transient uploads are kept on disk.
# Defaults to ./data inside the project root.
# BOT_DATA_DIR=./data

# WebP для ссылки в подписи к PNG (HTML): публичный URL = CDN_PUBLIC_BASE_URL/<userId>_<id>.webp
# Прокси: только домен → NODE (CDN_SERVE_PORT), без отдельного path-префикса.
# Файлы на диске: BOT_DATA_DIR/cdn-webp/<userId>_<id>.webp
# CDN_PUBLIC_BASE_URL=https://cdn.codesnippet.ru
# CDN_SERVE_PORT=5000
# Отключить локальный HTTP-сервер CDN: CDN_SERVE_DISABLED=1

# ─── MongoDB (recommended for persistent storage) ───────────────────────────
# When set, the bot stores users, styles, rules and generated images in Mongo
# instead of the local JSON file. Examples:
#   mongodb://localhost:27017/game-image-bot
#   mongodb+srv://user:pass@cluster.mongodb.net/game-image-bot
# MONGO_URI=
# Optional Mongo connection params override.
# MONGO_DB_NAME=

# ─── Redis queue (required for async generation jobs) ────────────────────────
# Background generation is processed via BullMQ + Redis.
# REDIS_URL=redis://127.0.0.1:6379
# GENERATION_QUEUE_NAME=image-generation
# GENERATION_QUEUE_CONCURRENCY=2

